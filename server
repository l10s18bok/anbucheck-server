#!/bin/zsh

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

case "$1" in
  start)
    cd "$SCRIPT_DIR"

    # pyenv 초기화
    export PYENV_ROOT="$HOME/.pyenv"
    export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init -)"
    pyenv local 3.10.0

    # venv 없으면 생성 + 패키지 설치
    if [ ! -d "venv" ]; then
      echo "가상환경 생성 중..."
      python3 -m venv venv
      source venv/bin/activate
      echo "패키지 설치 중..."
      pip install -r requirements.txt
    else
      source venv/bin/activate
    fi

    echo "서버 시작: http://localhost:8000"
    python3 main.py
    ;;
  *)
    echo "사용법: ./server start"
    ;;
esac
